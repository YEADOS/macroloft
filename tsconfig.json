{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun", "vite/client"],
    "paths": {
      "@server/*": ["./src/server/*"],
      "@shared/*": ["./src/shared/*"],
      "@client/*": ["./src/client/*"]
    }
  },
  "include": ["src", "scripts", "drizzle.config.ts", "vite.config.ts"]
}
