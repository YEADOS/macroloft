# MacroLoft container environment — template.
# Copy to docker/.env and fill in. docker/.env is gitignored (never committed).
#
# Compose auto-loads docker/.env when you run:
#   docker compose -f docker/compose.yml up --build
# (the project dir is the compose file's dir, so this .env is picked up there).

# AI photo estimation — API key for the vision provider.
# Optional: you can instead paste the key in the Settings page (stored in the
# DB). If set here, leave the Settings key field blank and the app falls back
# to this value. Local models usually need no key at all.
AI_API_KEY=
